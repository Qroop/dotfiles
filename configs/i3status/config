general {
	output_format = "i3bar"
	colors = true
	interval = 3
}

order += "wireless wlan0"
order += "ethernet etho0"
order += "battery 0"
order += "disk /"
order += "memory"
order += "tztime local"

memory {
	format = "%available"
}

tztime local {
        format = "%d/%m-%y %H:%M"
}

disk "/" {
	format = "%free"
}

battery 0 {
        format = "%status %percentage %remaining"
        format_down = "No battery"
		format_percentage = "%.00f%s"
		last_full_capacity = true
        status_chr = "CHR"
        status_bat = "BAT"
        status_unk = "UNK"
        status_full = "FULL"
        status_idle = "IDLE"
        path = "/sys/class/power_supply/BAT1/uevent"
        low_threshold = 10
}

wireless "wlan0" {
	format_up = "%essid: %bitrate"
	format_down = "W: down"
}

ethernet etho0 {
	format_up = "E: %ip %speed"	
	format_down = "E: down"
}
